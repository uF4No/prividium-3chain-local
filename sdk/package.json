{
  "name": "interop-sdk",
  "version": "1.0.0",
  "description": "zkSync Interop SDK for cross-chain communication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ethers": "^6.0.0",
    "zksync-ethers": "github:zksync-sdk/zksync-ethers#0cf0c171bbb07afd9a23b8796935d38ff3ab8661"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "keywords": [
    "zksync",
    "interop",
    "cross-chain",
    "ethereum",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  }
}
